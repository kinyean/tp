@startuml
!include style.puml
skinparam ArrowFontStyle plain
skinparam ParticipantPadding 18
skinparam BoxPadding 10
skinparam SequenceMessageAlign center
skinparam NoteBackgroundColor #FFF7CC
skinparam NoteBorderColor #888888
skinparam NoteFontColor #111111
skinparam ArrowFontColor #111111
skinparam SequenceLifeLineBorderColor #666666
skinparam SequenceLifeLineBackgroundColor #F8F8F8
hide footbox

actor User USER_COLOR

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "a:ArchiveCommand" as ArchiveCommand LOGIC_COLOR
participant "l:ListCommand" as ListCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

== Archive application ==

User -> LogicManager : execute("archive 1")
activate LogicManager

LogicManager -> ArchiveCommand : execute(m)
activate ArchiveCommand

ArchiveCommand -> Model : getFilteredApplicationList()
activate Model
deactivate Model

ArchiveCommand -> Model : setApplication(archivedCopy)
activate Model
deactivate Model

deactivate ArchiveCommand
deactivate LogicManager

== Show archived view ==

User -> LogicManager : execute("list archived")
activate LogicManager

create ListCommand
LogicManager -> ListCommand
activate ListCommand

LogicManager -> ListCommand : execute(m)

ListCommand -> Model : updateFilteredApplicationList(\nshow archived)
activate Model
deactivate Model

deactivate ListCommand
deactivate LogicManager

note across
Default list view excludes archived applications.
`list archived` switches the current predicate
to show only archived applications.
Archive, edit, and unarchive keep the current predicate.
end note
@enduml
