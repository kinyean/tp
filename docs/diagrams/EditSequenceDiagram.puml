@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":EditCommandParser" as EditCommandParser LOGIC_COLOR
participant "d:EditCommand" as EditCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
participant "e:EditApplicationDescriptor" as EditApplicationDescriptor LOGIC_COLOR
participant "editedApplication:Application" as Application LOGIC_COLOR
box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("edit 1 n/ Grab")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("edit 1 n/ Grab")
activate AddressBookParser

create EditCommandParser
AddressBookParser -> EditCommandParser
activate EditCommandParser

EditCommandParser --> AddressBookParser
deactivate EditCommandParser

AddressBookParser -> EditCommandParser : parse("1 n/ Grab")
activate EditCommandParser

create EditApplicationDescriptor
EditCommandParser -> EditApplicationDescriptor
activate EditApplicationDescriptor

EditApplicationDescriptor --> EditCommandParser : e
deactivate EditApplicationDescriptor

create EditCommand
EditCommandParser -> EditCommand : EditCommand(1, e)
activate EditCommand

EditCommand --> EditCommandParser :
deactivate EditCommand

EditCommandParser --> AddressBookParser : d
deactivate EditCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
EditCommandParser -[hidden]-> AddressBookParser
destroy EditCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> EditCommand : execute(m)
activate EditCommand

EditCommand -> Model : retrieve application list
activate Model

Model --> EditCommand : lastShownList
deactivate Model

EditCommand -> EditApplicationDescriptor : getName()
activate EditApplicationDescriptor

EditApplicationDescriptor --> EditCommand : "Grab"
deactivate EditApplicationDescriptor

create Application
EditCommand -> Application
activate Application

Application --> EditCommand : editedApplication
deactivate Application

EditCommand -> Model : update application

create CommandResult
EditCommand -> CommandResult
activate CommandResult

CommandResult --> EditCommand : r
deactivate CommandResult

EditCommand --> LogicManager : r
deactivate EditCommand

[<--LogicManager
deactivate LogicManager
@enduml
