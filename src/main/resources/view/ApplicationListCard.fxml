<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <StackPane HBox.hgrow="ALWAYS">
    <GridPane HBox.hgrow="ALWAYS">
      <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
      </columnConstraints>
      <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0">
        <padding>
          <Insets top="5" right="5" bottom="5" left="15" />
        </padding>
        <HBox spacing="0.5" alignment="TOP_LEFT">
          <Label fx:id="id" styleClass="cell_big_label">
            <minWidth>
              <!-- Ensures that the label text is never truncated -->
              <Region fx:constant="USE_PREF_SIZE" />
            </minWidth>
          </Label>
          <Label fx:id="companyName" text="\$first" styleClass="cell_big_label" wrapText="true" minWidth="0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        </HBox>
        <FlowPane fx:id="tags" />
        <HBox spacing="5" alignment="TOP_LEFT">
            <ImageView fitHeight="16" fitWidth="16">
                <image>
                    <Image url="@../images/role.png" />
                </image>
            </ImageView>
            <Label fx:id="role" styleClass="cell_small_label" text="\$role" wrapText="true" minWidth="0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        </HBox>
        <HBox spacing="5" alignment="TOP_LEFT">
            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                <image>
                    <Image url="@../images/address.png" />
                </image>
            </ImageView>
            <Label fx:id="address" styleClass="cell_small_label" text="\$address" wrapText="true" minWidth="0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        </HBox>
        <HBox spacing="5" alignment="TOP_LEFT">
            <ImageView fitHeight="16" fitWidth="16">
                <image>
                    <Image url="@../images/email.png" />
                </image>
            </ImageView>
            <Label fx:id="email" styleClass="cell_small_label" text="\$email" wrapText="true" minWidth="0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        </HBox>
        <HBox spacing="5" alignment="TOP_LEFT">
            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                <image>
                    <Image url="@../images/website.png" />
                </image>
            </ImageView>
            <Label fx:id="website" styleClass="cell_small_label" text="\$website" wrapText="true" minWidth="0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
        </HBox>
        <HBox spacing="5" alignment="CENTER_LEFT">
            <ImageView fitHeight="16" fitWidth="16">
                <image>
                    <Image url="@../images/date.png" />
                </image>
            </ImageView>
            <Label fx:id="date" styleClass="cell_small_label" text="\$date" />
        </HBox>
        <HBox spacing="5" alignment="CENTER_LEFT">
            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                <image>
                    <Image url="@../images/status.png" />
                </image>
            </ImageView>
            <Label fx:id="status" styleClass="cell_small_label" text="\$status" />
        </HBox>
      </VBox>
    </GridPane>
    <Label fx:id="archivedLabel" managed="false" styleClass="archived-label" text="ARCHIVED"
           visible="false" StackPane.alignment="TOP_RIGHT" />
  </StackPane>
</HBox>
